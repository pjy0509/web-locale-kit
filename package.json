{
  "name": "web-locale-kit",
  "version": "0.0.1",
  "description": "TypeScript locale detector — resolves the user's language(s), timezone, UTC offset, and text direction (RTL/LTR) from Intl and navigator, with normalization and graceful fallbacks.",
  "author": "Park Jungyoung <qkrwnss0509@gmail.com> (https://github.com/pjy0509)",
  "type": "module",

  "sideEffects": false,

  "main": "dist/locale-kit.cjs",
  "module": "dist/locale-kit.mjs",
  "browser": "dist/locale-kit.umd.js",
  "types": "dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/locale-kit.mjs",
      "require": "./dist/locale-kit.cjs",
      "default": "./dist/locale-kit.mjs"
    }
  },

  "files": [
    "dist/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },

  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "git+https://github.com/pjy0509/web-locale-kit.git"
  },
  "homepage": "https://pjy0509.github.io/example/web-locale-kit/",
  "keywords": [
    "locale",
    "language",
    "i18n",
    "intl",
    "timezone",
    "timezone-offset",
    "rtl",
    "ltr",
    "text-direction",
    "navigator-language",
    "browser",
    "webview",
    "pwa"
  ],
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
